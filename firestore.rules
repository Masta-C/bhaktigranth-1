rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts — published posts readable by anyone; authenticated admin can read all
    match /posts/{postId} {
      allow read: if resource.data.status == "published" || request.auth != null;
      allow write: if request.auth != null;
    }

    // Vlogs — published vlogs readable by anyone; authenticated admin can read all
    match /vlogs/{vlogId} {
      allow read: if resource.data.status == "published" || request.auth != null;
      allow write: if request.auth != null;
    }

    // Q&A — anyone can read published; authenticated admin can read all; public can submit
    match /qna/{qnaId} {
      allow read: if resource.data.status == "published" || request.auth != null;
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.answer == null
                    && request.resource.data.question is string
                    && request.resource.data.question.size() > 0
                    && request.resource.data.question.size() < 1000;
      allow update, delete: if request.auth != null;
    }
  }
}
