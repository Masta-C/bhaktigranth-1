rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Published posts — anyone can read
    match /posts/{postId} {
      allow read: if resource.data.status == "published";
      allow write: if request.auth != null;
    }

    // Published vlogs — anyone can read
    match /vlogs/{vlogId} {
      allow read: if resource.data.status == "published";
      allow write: if request.auth != null;
    }

    // Q&A — anyone can read published, anyone can create (submit question), admin can update/delete
    match /qna/{qnaId} {
      allow read: if resource.data.status == "published";
      allow create: if request.resource.data.status == "pending"
                    && request.resource.data.answer == null
                    && request.resource.data.question is string
                    && request.resource.data.question.size() > 0
                    && request.resource.data.question.size() < 1000;
      allow update, delete: if request.auth != null;
    }
  }
}
